<UserControl x:Class="HCLauncher.Components.GameVersion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HCLauncher.Components"
             mc:Ignorable="d" d:DesignWidth="800" Height="64">
    <Grid Margin="0,0,0,386">
        <Image x:Name="imgVersionIcon" HorizontalAlignment="Left" Height="64" Margin="1,0,0,0" VerticalAlignment="Top" Width="64"/>
        <Label x:Name="lblVersionCustomName" Content="Label" HorizontalAlignment="Left" Margin="100,10,0,0" VerticalAlignment="Top" Height="25" Width="200"/>

    </Grid>
</UserControl>
