<UserControl x:Class="HCLauncher.Components.PageSelection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HCLauncher.Components"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="80">
    <Grid>
        <Label x:Name="lblSelectionName" Content="Label" HorizontalAlignment="Left" Margin="30,0,0,0" VerticalAlignment="Center" Width="50"/>
        <Image x:Name="imgSelectionIcon" HorizontalAlignment="Left" Height="30" VerticalAlignment="Top" Width="30" Margin="0,0,0,0"/>

    </Grid>
</UserControl>
